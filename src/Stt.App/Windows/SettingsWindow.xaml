<Window x:Class="Stt.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="whisper Settings"
        Icon="/Assets/whisper.ico"
        Width="560"
        Height="520"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#E6ECE4">
    <Grid Margin="16">
        <Border CornerRadius="18"
                Background="#FFFDF7"
                BorderBrush="#D6DECE"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Bottom"
                        Padding="22,14,22,18"
                        BorderBrush="#E4EADF"
                        BorderThickness="0,1,0,0"
                        Background="#FFFDF7">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Padding="16,8"
                                Margin="0,0,10,0"
                                Command="{Binding CancelCommand}"
                                Background="#E7ECE3"
                                BorderBrush="#CDD8C7"
                                Foreground="#203126"
                                Content="Cancel" />
                        <Button Padding="18,8"
                                Command="{Binding SaveCommand}"
                                Background="#203126"
                                BorderBrush="#203126"
                                Foreground="#FFFDF7"
                                Content="Save" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,22,22,18">
                        <StackPanel>
                            <TextBlock Text="OpenAI API Key"
                                       Foreground="#33453A"
                                       FontWeight="SemiBold" />
                            <TextBox Margin="0,8,0,0"
                                     Padding="12,10"
                                     Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#FFFDF7"
                                     BorderBrush="#CCD7C5"
                                     Foreground="#162018" />
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Microphone"
                                       Foreground="#33453A"
                                       FontWeight="SemiBold" />
                            <ComboBox Margin="0,8,0,0"
                                      Padding="10,6"
                                      ItemsSource="{Binding AvailableMicrophones}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="DeviceId"
                                      SelectedValue="{Binding SelectedMicrophoneDeviceId, UpdateSourceTrigger=PropertyChanged}"
                                      Background="#FFFDF7"
                                      BorderBrush="#CCD7C5"
                                      Foreground="#162018" />
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Start / End Recording Hotkey"
                                       Foreground="#33453A"
                                       FontWeight="SemiBold" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="HotkeyTextBox"
                                         Padding="12,10"
                                         IsReadOnly="True"
                                         Text="{Binding ToggleRecordingHotkey, Mode=OneWay}"
                                         PreviewKeyDown="HotkeyTextBox_OnPreviewKeyDown"
                                         PreviewTextInput="HotkeyTextBox_OnPreviewTextInput"
                                         Background="#FFFDF7"
                                         BorderBrush="#CCD7C5"
                                         Foreground="#162018" />

                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Padding="14,8"
                                        Click="ClearHotkeyButton_OnClick"
                                        Background="#E7ECE3"
                                        BorderBrush="#CDD8C7"
                                        Foreground="#203126"
                                        Content="Clear" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding LaunchOnWindowsLogin}"
                                      Foreground="#203126"
                                      Content="Launch on Windows login" />
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding AutoPasteAfterCopy}"
                                      Foreground="#203126"
                                      Content="Auto-paste to current focus" />
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding ShowTranscriptWindowWhenSpeaking}"
                                      Foreground="#203126"
                                      Content="Pop up transcript window when speaking" />
                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding EnableStreamingTranscription}"
                                      Foreground="#203126"
                                      Content="Streaming for faster transcription" />
                        </StackPanel>

                        <Border Margin="0,18,0,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="#EEF3EB"
                                BorderBrush="#D7E1D2"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EnableStreamingTranscription}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Streaming setup"
                                           Foreground="#33453A"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Tune based on your speaking pace."
                                           Foreground="#617362"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,16,0,0"
                                           Text="VAD mode"
                                           Foreground="#33453A"
                                           FontWeight="SemiBold" />
                                <ComboBox Margin="0,8,0,0"
                                          Padding="10,6"
                                          ItemsSource="{Binding AvailableRealtimeVadModes}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedRealtimeVadMode, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#FFFDF7"
                                          BorderBrush="#CCD7C5"
                                          Foreground="#162018" />

                                <StackPanel Margin="0,12,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerVadSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="Silence duration (ms)"
                                               Foreground="#33453A"
                                               FontWeight="SemiBold" />
                                    <TextBox Margin="0,8,0,0"
                                             Padding="12,10"
                                             Text="{Binding RealtimeSilenceDurationMsText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#FFFDF7"
                                             BorderBrush="#CCD7C5"
                                             Foreground="#162018" />
                                </StackPanel>

                                <StackPanel Margin="0,12,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSemanticVadSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="Semantic eagerness"
                                               Foreground="#33453A"
                                               FontWeight="SemiBold" />
                                    <ComboBox Margin="0,8,0,0"
                                              Padding="10,6"
                                              ItemsSource="{Binding AvailableRealtimeVadEagernessOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedRealtimeVadEagerness, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#FFFDF7"
                                              BorderBrush="#CCD7C5"
                                              Foreground="#162018" />
                                </StackPanel>

                                <TextBlock Margin="0,12,0,0"
                                           Text="Max streaming length (minutes)"
                                           Foreground="#33453A"
                                           FontWeight="SemiBold" />
                                <TextBox Margin="0,8,0,0"
                                         Padding="12,10"
                                         Text="{Binding MaxStreamingLengthMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#FFFDF7"
                                         BorderBrush="#CCD7C5"
                                         Foreground="#162018" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="#EEF3EB"
                                BorderBrush="#D7E1D2"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Settings file"
                                           Foreground="#33453A"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SettingsPath}"
                                           Foreground="#617362"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
